+			compatible = "infineon,radar";
+
+			reg = <0x24>;
+			devnode = "video1";
+
+			/* Physical dimensions of sensor */
+			physical_w = "15.0";
+			physical_h = "12.5";
+
+			sensor_model ="radar";
