+	{0x80,0x02E5,0x9B},
+	{0x80,0x02E6,0xA3},
+	{0x80,0x02E7,0x43},
+	//A RESET DES8->SER9
+	{0x90,0x02C8,0x9B},
+	{0x90,0x02C9,0xA4},
+	{0x90,0x02CA,0x44},
+	{0x80,0x02D9,0x84},
+	{0x80,0x02DA,0xA4},
+	{0x80,0x02DB,0x44},
+	//A DMUX1 DES9->SER3
