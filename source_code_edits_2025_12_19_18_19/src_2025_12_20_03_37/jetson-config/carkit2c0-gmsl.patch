+#include <t234-common-modules/tegra234-camera-infineon-radar-a00.dtsi>
+#include "dt-bindings/clock/tegra234-clock.h"
+
+#define CAM0_RST_L	TEGRA234_MAIN_GPIO(H, 3)
+#define CAM0_PWDN	TEGRA234_MAIN_GPIO(H, 6)
+#define CAM1_RST_L	TEGRA234_MAIN_GPIO(AC, 2)
+#define CAM1_PWDN	TEGRA234_MAIN_GPIO(AC, 0)
+#define PWR_EN      TEGRA234_MAIN_GPIO(M, 5)
+#define CAMERA_I2C_MUX_BUS(x) (0x1E + x)
+
+/* camera control gpio definitions */
+
+/ {
+	spi@c260000{ /* hardware pin name SPI2 */
+		compatible = "nvidia,tegra186-spi";
+		status = "okay";
+		spi@0 { /* chip select 0 */
+			compatible = "tegra-spidev";
+			reg = <0x0>;
+			spi-max-frequency = <50000000>;
+			controller-data {
+				nvidia,enable-hw-based-cs;
+				nvidia,rx-clk-tap-delay = <0x10>;
+				nvidia,tx-clk-tap-delay = <0x0>;
+			};
+		};
+	};
+
+	i2c@3180000 {
+		max929x_a@48 {
+			compatible = "nvidia,max929x";
+			deser-index = <0>;
+			reg = <0x48>;
+			pwdn-gpios = <&tegra_main_gpio CAM0_RST_L GPIO_ACTIVE_HIGH>;
+		};
+		radar_a@23 {
+			/* Define any required hw resources needed by driver */
+			/* ie. clocks, io pins, power sources */
+			clocks = <&bpmp_clks TEGRA234_CLK_EXTPERIPH1>,
+						<&bpmp_clks TEGRA234_CLK_EXTPERIPH1>;
+			port-index = <0>;
+			clock-names = "extperiph1", "pllp_grtba";
+			mclk = "extperiph1";
+		};
+		radar_b@24 {
+			/* Define any required hw resources needed by driver */
+			/* ie. clocks, io pins, power sources */
+			clocks = <&bpmp_clks TEGRA234_CLK_EXTPERIPH1>,
+						<&bpmp_clks TEGRA234_CLK_EXTPERIPH1>;
+			port-index = <1>;
+			clock-names = "extperiph1", "pllp_grtba";
+			mclk = "extperiph1";
+		};
+	};
+};
