+/ {
+	tegra-capture-vi {
+			num-channels = <2>;
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+				port@0 {
+					reg = <0>;
+					radar_vi_in0: endpoint {
+						port-index = <0>;
+						bus-width = <4>;
+						vc-id = <0>;
+						remote-endpoint = <&radar_csi_out0>;
+					};
+				};
+				port@1 {
+					reg = <1>;
+					radar_vi_in1: endpoint {
+						port-index = <2>;
+						bus-width = <4>;
+						vc-id = <0>;
+						remote-endpoint = <&radar_csi_out1>;
+					};
+				};
+			};
+		};
+	host1x@13e00000 {
+		nvcsi@15a00000 {
+			num-channels = <2>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			channel@0 {
+				reg = <0>;
+				ports {
+					#address-cells = <1>;
+					#size-cells = <0>;
+					port@0 {
+						reg = <0>;
+						radar_csi_in0: endpoint@0 {
+							port-index = <0>;
+							bus-width = <4>;
+							remote-endpoint = <&radar_out0>;
+						};
+					};
+					port@1 {
+						reg = <1>;
+						radar_csi_out0: endpoint@1 {
+							remote-endpoint = <&radar_vi_in0>;
+						};
+					};
+				};
+			};
+			channel@1 {
+				reg = <1>;
+				ports {
+					#address-cells = <1>;
+					#size-cells = <0>;
+					port@0 {
+						reg = <0>;
+						radar_csi_in1: endpoint@0 {
+							port-index = <2>;
+							bus-width = <4>;
+							remote-endpoint = <&radar_out1>;
+						};
+					};
+					port@1 {
+						reg = <1>;
+						radar_csi_out1: endpoint@1 {
+							remote-endpoint = <&radar_vi_in1>;
+						};
+					};
+				};
+			};
+		};
+	};
+
+	i2c@3180000 {
+		radar_a@23 {
+			compatible = "infineon,radar";
+
+			reg = <0x23>;
+			devnode = "video0";
+
+			/* Physical dimensions of sensor */
+			physical_w = "15.0";
+			physical_h = "12.5";
+
+			sensor_model ="radar";
+			/* Define any required hw resources needed by driver */
+			/* ie. clocks, io pins, power sources */
+
+			/* Defines number of frames to be dropped by driver internally after applying */
+			/* sensor crop settings. Some sensors send corrupt frames after applying */
+			/* crop co-ordinates */
+			post_crop_frame_drop = "0";
+
+			/* Convert Gain to unit of dB (decibel) befor passing to kernel driver */
+			use_decibel_gain = "true";
+
+			/* if true, delay gain setting by one frame to be in sync with exposure */
+			delayed_gain = "true";
+
+			/* disable CID_SENSOR_MODE_ID for sensor modes selection */
+			/* by setting to false -> enable setting width and height over v4l2ctl */
+			use_sensor_mode_id = "false";
+
+			#include "tegra234-camera-infineon-radar-a00-modes.dtsi"
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+				port@0 {
+					reg = <0>;
+					radar_out0: endpoint {
+						port-index = <0>;
+						bus-width = <4>;
+						vc-id = <0>;
+						remote-endpoint = <&radar_csi_in0>;
+					};
+				};
+			};
+		};
