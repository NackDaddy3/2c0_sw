+	{0x90,0x0313,0x02}, //  (CSI_OUT_EN): CSI output enabled
+	// Video Transmit Configuration for Serializer(s)
+	{0x80,0x0002,0x43}, // DEV : REG2 | VID_TX_EN_X (VID_TX_EN_X): Disabled | VID_TX_EN_Y (VID_TX_EN_Y): Disabled
+
+	{0x90,0x0005,0x00},
+	{0x80,0x0005,0x00},
